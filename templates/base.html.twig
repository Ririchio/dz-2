<!DOCTYPE html>
<html lang="ru">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}PostLab{% endblock %}</title>
        <style>
            body { margin: 0; background: #f4f6fb; color: #202536; font-family: Arial, sans-serif; }
            a { color: #4b4bb5; text-decoration: none; }
            .navbar { background: #24283b; }
            .navbar-inner { max-width: 960px; margin: auto; padding: 20px; display: flex; justify-content: space-between; }
            .brand, .nav-links a { color: white; }
            .brand { font-size: 20px; font-weight: bold; }
            .nav-links a { margin-left: 15px; }
            .page { max-width: 960px; margin: 30px auto; padding: 0 20px; }
            h1, h2 { margin-top: 0; }
            .card { background: white; border: 1px solid #ddd; border-radius: 8px; padding: 20px; margin-bottom: 15px; }
            .muted, .comment-meta { color: #777; }
            .actions, .reactions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 15px; }
            button, .button { padding: 10px 15px; border: 0; border-radius: 5px; background: #5555c7; color: white; cursor: pointer; }
            .button-secondary { background: #e7e7f2; color: #333; }
            .button-danger { background: #bd4444; }
            form > div { margin-bottom: 15px; }
            label { display: block; margin-bottom: 5px; }
            input, textarea { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; box-sizing: border-box; }
            textarea { min-height: 120px; }
            .form-card, .auth-card { max-width: 600px; margin: auto; }
            .auth-card { max-width: 440px; }
            .alert { padding: 12px; margin-bottom: 15px; border-radius: 5px; }
            .alert-error { background: #ffe3e3; }
            .post-list-item { display: flex; justify-content: space-between; gap: 20px; }
            .post-preview { flex: 1; }
            .section { margin-top: 30px; }
            .comment { border-left: 4px solid #cccced; }
            .comment-content { white-space: pre-wrap; }
            .reaction-button { background: #eee; color: #333; }
            .reaction-button.active { background: #5555c7; color: white; }
            .empty-state { text-align: center; color: #777; }
            .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
            .stat-value { font-size: 20px; font-weight: bold; }
            @media (max-width: 700px) {
                .navbar-inner, .post-list-item { display: block; }
                .nav-links { margin-top: 15px; }
                .nav-links a { margin: 0 10px 0 0; }
                .stats-grid { grid-template-columns: 1fr; }
            }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <header class="navbar">
            <div class="navbar-inner">
                <a class="brand" href="{{ app.user ? path('app_profile') : path('app_login') }}">PostLab</a>
                <nav class="nav-links">
                    {% if app.user %}
                        <a href="{{ path('app_profile') }}">Профиль</a>
                        <a href="{{ path('app_post') }}">Лента</a>
                        {% if app.user.profile %}<a href="{{ path('app_post_mine') }}">Мои посты</a>{% endif %}
                        {% if is_granted('ROLE_ADMIN') %}<a href="{{ path('app_statistics') }}">Статистика</a>{% endif %}
                        <a href="/logout">Выйти</a>
                    {% else %}
                        <a href="{{ path('app_login') }}">Войти</a>
                        <a href="{{ path('app_registration') }}">Регистрация</a>
                    {% endif %}
                </nav>
            </div>
        </header>

        <main class="page">
            {% for message in app.flashes('error') %}
                <div class="alert alert-error">{{ message }}</div>
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
        {% block javascripts %}{% endblock %}
    </body>
</html>
