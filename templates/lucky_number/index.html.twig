{% extends 'base.html.twig' %}

{% block title %}LuckyNumber index{% endblock %}

{% block body %}
    <h1>LuckyNumber index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Value</th>
                <th>Author</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for lucky_number in lucky_numbers %}
            <tr>
                <td>{{ lucky_number.id }}</td>
                <td>{{ lucky_number.value }}</td>
                <td>{{ lucky_number.author }}</td>
                <td>
                    <a href="{{ path('app_lucky_number_show', {'id': lucky_number.id}) }}">show</a>
                    <a href="{{ path('app_lucky_number_edit', {'id': lucky_number.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_lucky_number_new') }}">Create new</a>
{% endblock %}
