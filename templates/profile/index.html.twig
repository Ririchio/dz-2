{% extends 'base.html.twig' %}

{% block title %}Профиль{% endblock %}

{% block body %}
    <h1>Профиль</h1>

    {% if user.profile %}
        <section class="card">
            <p class="muted" style="margin-top: 0">{{ user.email }}</p>
            <h2>О себе</h2>
            <p>{{ user.profile.bio ?: 'Описание профиля пока не заполнено.' }}</p>

            <div class="actions">
                <a class="button" href="{{ path('app_post') }}">Общая лента</a>
                <a class="button button-secondary" href="{{ path('app_post_mine') }}">Мои посты</a>
                <a class="button button-secondary" href="{{ path('app_profile_edit') }}">Редактировать профиль</a>
                <form method="post" action="{{ path('app_profile_delete') }}" onsubmit="return confirm('Удалить профиль?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-profile') }}">
                    <button class="button-danger">Удалить профиль</button>
                </form>
            </div>
        </section>
    {% else %}
        <section class="card empty-state">
            <h2>Профиль ещё не создан</h2>
            <p>Создайте профиль, чтобы публиковать посты и комментарии.</p>
            <a class="button" href="{{ path('app_profile_new') }}">Создать профиль</a>
        </section>
    {% endif %}
{% endblock %}
