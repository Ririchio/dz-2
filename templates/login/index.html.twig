{% extends 'base.html.twig' %}

{% block title %}Вход{% endblock %}

{% block body %}
    <section class="card auth-card">
        <h1>Вход</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="alert alert-error">Неверный email или пароль.</div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <div>
                <label for="_username">Email</label>
                <input type="email" id="_username" name="_username" value="{{ last_username }}" required autofocus>
            </div>
            <div>
                <label for="_password">Пароль</label>
                <input type="password" id="_password" name="_password" required>
            </div>
            <button style="width: 100%">Войти</button>
        </form>

        <p class="auth-footer">Нет аккаунта? <a href="{{ path('app_registration') }}">Зарегистрироваться</a></p>
    </section>
{% endblock %}
